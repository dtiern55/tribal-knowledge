DB_HOST=db.[PROJECT-REF].supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=[YOUR-PASSWORD]
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Public anon key (same one the frontend uses) — needed by scripts/ that log
# in as the producer, e.g. scripts/import_episode.py.
SUPABASE_ANON_KEY=[ANON-KEY]
# Producer (admin) login used by scripts/import_episode.py.
PRODUCER_EMAIL=[ADMIN-EMAIL]
PRODUCER_PASSWORD=[ADMIN-PASSWORD]
# Only needed by scripts/load_headshots.py (storage upload). Keep out of the
# deployed app; dashboard or `supabase projects api-keys` has it.
SUPABASE_SERVICE_ROLE_KEY=[SERVICE-ROLE-KEY]
# In production, set this to the real deployed frontend origin (e.g. the
# Vercel URL) -- multiple origins are comma-separated.
CORS_ORIGINS=http://localhost:5173
# Optional regex for additional allowed origins (prod sets this in fly.toml
# so Vercel preview deployments can hit the API).
# CORS_ORIGIN_REGEX=
